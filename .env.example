# FormForge environment variables
# Copy this file to `.env.local` for local development and fill in the values
# from your Supabase project (Settings > API). For production, set these in your
# host's dashboard (e.g. Netlify > Site settings > Environment variables).
#
# Only the publishable (anon) key belongs here — never the service_role key.

# Your Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=https://project-id.supabase.co

# Your Supabase publishable / anon key
VITE_SUPABASE_PUBLISHABLE_KEY=key
